# ============================================================
# Buddhist Affairs MIS Dashboard - Frontend Environment Config
# ============================================================
# DO NOT COMMIT THIS FILE TO GIT
# Vite bakes these values into the build at compile time.
# For Railway: set these as environment variables in the Railway dashboard.
# ============================================================

# Backend API base URL (include /api/v1)
# Local dev:
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Production (Railway) — replace with your actual backend URL:
# VITE_API_BASE_URL=https://YOUR-BACKEND.up.railway.app/api/v1

# Application display name (optional)
VITE_APP_NAME=Buddhist Affairs MIS Dashboard
